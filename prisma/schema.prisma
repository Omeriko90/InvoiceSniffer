generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

enum ExtractionMethod {
  HEURISTIC
  AI
  MANUAL
}

enum InvoiceStatus {
  DETECTED
  REVIEWED
  MATCHED
  UNMATCHED
  IGNORED
}

enum AliasType {
  POSITIVE
  NEGATIVE
  IGNORE
}

enum AliasSource {
  USER
  SYSTEM_LEARNED
}

enum AnomalyType {
  AMOUNT_HIGH
  AMOUNT_LOW
  SPEND_SPIKE
  MISSING_RECURRING
  NEW_VENDOR
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
}

enum ExportStatus {
  QUEUED
  BUILDING
  READY
  EXPIRED
  FAILED
}

enum ExportFormat {
  CSV
  XLSX
  PDF
}

enum TransactionStatus {
  UNMATCHED
  POSSIBLE
  MATCHED
  NO_INVOICE
}

// ─── Models ───────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  planTier  PlanTier @default(FREE)
  // Max days a card charge may post AFTER its invoice (credit-card settlement
  // lag). Widens the reconcile match window on the "invoice precedes charge"
  // side and the invoice-candidate lookback. Configurable per org.
  settlementLagDays Int @default(30)
  createdAt DateTime @default(now())

  users            User[]
  gmailCredentials GmailCredential[]
  invoices         Invoice[]
  vendorAliases   VendorAlias[]
  vendorStats     VendorStats[]
  anomalyLogs     AnomalyLog[]
  exportJobs      ExportJob[]
  transactions    Transaction[]
  csvMappings     CsvMapping[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  googleId       String?   @unique
  role           UserRole  @default(MEMBER)
  organizationId String
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts     Account[]
  sessions     Session[]
}

// ─── NextAuth tables ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Gmail ────────────────────────────────────────────────

model GmailCredential {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  label          String? // user-facing display name; falls back to email
  accessToken    String // AES-256-GCM encrypted
  refreshToken   String // AES-256-GCM encrypted
  expiresAt      DateTime
  scopes         String[]
  connected      Boolean   @default(true)
  syncToken      String? // Gmail historyId for incremental syncs
  lastSyncedAt   DateTime?
  watchExpiry    DateTime? // Pub/Sub watch expiry — renew every 6 days
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@unique([organizationId, email])
}

// ─── Invoices ─────────────────────────────────────────────

model Invoice {
  id                   String           @id @default(cuid())
  organizationId       String
  gmailCredentialId    String? // source mailbox; nullable only for pre-migration orphans
  gmailMessageId       String
  gmailThreadId        String
  gmailLink            String
  senderEmail          String
  senderName           String?
  subject              String
  emailDate            DateTime
  vendorName           String?
  vendorNormalized     String?
  invoiceNumber        String?
  invoiceDate          DateTime?
  dueDate              DateTime?
  totalAmount          Decimal          @db.Decimal(12, 2)
  currency             String           @default("USD")
  taxAmount            Decimal?         @db.Decimal(12, 2)
  lineItems            Json             @default("[]")
  attachmentMeta       Json             @default("[]")
  receiptUrl           String?
  extractionMethod     ExtractionMethod @default(HEURISTIC)
  extractionConfidence Float            @default(0)
  status               InvoiceStatus    @default(DETECTED)
  anomalyFlag          Boolean          @default(false)
  // Provenance from the reconcile session that matched this invoice: which CSV
  // it was reconciled against and when. Nullable — set on confirm/link, cleared
  // on undo. Powers the "reconciled against <file>" breadcrumb and collision
  // warnings when a later session re-matches an already-reconciled invoice.
  reconciledSourceFile String?
  reconciledAt         DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gmailCredential GmailCredential? @relation(fields: [gmailCredentialId], references: [id], onDelete: SetNull)
  anomalyLogs     AnomalyLog[]
  transactions    Transaction[]

  @@unique([organizationId, gmailMessageId])
  @@index([organizationId, emailDate])
  @@index([organizationId, vendorNormalized])
  @@index([organizationId, status])
  @@index([gmailCredentialId])
}

// ─── Learning ─────────────────────────────────────────────

model VendorAlias {
  id              String      @id @default(cuid())
  organizationId  String
  merchantPattern String
  vendorName      String
  senderEmail     String?
  type            AliasType
  source          AliasSource @default(USER)
  useCount        Int         @default(0)
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, merchantPattern])
  @@index([organizationId, type, active])
}

// ─── Analytics ────────────────────────────────────────────

model VendorStats {
  id                String   @id @default(cuid())
  organizationId    String
  vendorName        String
  invoiceCount      Int      @default(0)
  avgAmount         Decimal  @db.Decimal(12, 2)
  medianAmount      Decimal  @db.Decimal(12, 2)
  stdDevAmount      Decimal  @db.Decimal(12, 2) @default(0)
  minAmount         Decimal  @db.Decimal(12, 2)
  maxAmount         Decimal  @db.Decimal(12, 2)
  typicalDayOfMonth Int?
  isRecurring       Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, vendorName])
}

model AnomalyLog {
  id             String          @id @default(cuid())
  organizationId String
  invoiceId      String?
  vendorName     String
  type           AnomalyType
  severity       AnomalySeverity
  details        Json
  acknowledged   Boolean         @default(false)
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, acknowledged])
}

// ─── Exports ──────────────────────────────────────────────

model ExportJob {
  id             String       @id @default(cuid())
  organizationId String
  format         ExportFormat @default(PDF)
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  invoiceIds     String[]
  // Chosen spreadsheet columns (CSV/XLSX); empty for PDF.
  fields         String[]
  status         ExportStatus @default(QUEUED)
  r2Key          String?
  downloadUrl    String?
  fileName       String?
  mimeType       String?
  // Invoices with no PDF / a fetch failure — [{ invoiceId, vendorName, reason }].
  skippedCount   Int          @default(0)
  skipped        Json         @default("[]")
  startedAt      DateTime?
  finishedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([status])
}

// ─── Transactions (CSV imports) ───────────────────────────

model Transaction {
  id               String            @id @default(cuid())
  organizationId   String
  date             DateTime
  merchant         String
  amount           Decimal           @db.Decimal(12, 2)
  currency         String            @default("USD")
  status           TransactionStatus @default(UNMATCHED)
  matchedInvoiceId String?
  matchConfidence  Float?
  matchReason      String?
  matchConfirmed   Boolean           @default(false)
  sourceFile       String?
  // Natural-key hash (date|merchant|amount|currency) set at import time so a
  // re-uploaded statement dedupes instead of doubling transactions. Nullable:
  // rows imported before this column stay null (Postgres allows many nulls in a
  // unique index), so no backfill is needed and only new imports are deduped.
  dedupeKey        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matchedInvoice Invoice?     @relation(fields: [matchedInvoiceId], references: [id], onDelete: SetNull)

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, date])
  @@index([organizationId, status])
}

model CsvMapping {
  id             String   @id @default(cuid())
  organizationId String
  label          String   // e.g. "Amex" — shown as "Saved mapping for Amex"
  headersKey     String   // normalized CSV header signature used for auto-apply
  mapping        Json     // { date, merchant, amount, currency? } → CSV column names
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, headersKey])
}
